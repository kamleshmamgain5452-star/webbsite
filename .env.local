# DesignFlow Environment Variables
# Set these in your Vercel dashboard under Settings > Environment Variables

# 1. AI Keys (Get from console.groq.com)
# On Vercel: add GROQ_API_KEY as a secret environment variable
GROQ_API_KEY=

# 2. WebSocket Relay (Your deployed Railway/Render URL)
# IMPORTANT: Change this to your real deployed relay URL after deploying cloud-relay.js
# Example: wss://designflow-relay.up.railway.app
NEXT_PUBLIC_RELAY_URL=wss://connector-production-cc6f.up.railway.app

# 3. Session Info (Optional defaults)
NEXT_PUBLIC_DEFAULT_SESSION_KEY=kamlesh-studio
